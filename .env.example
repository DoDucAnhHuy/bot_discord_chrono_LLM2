# ── Discord ───────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# (Optional) Your server/guild ID for instant command sync during dev.
# Leave blank for global deployment.
GUILD_ID=123456789012345678

# Channel where ⚠️ respawn alerts will be posted.
ALERT_CHANNEL_ID=987654321098765432

# ── Firebase ──────────────────────────────────────────────
# Path to the service-account JSON file downloaded from Firebase console.
# Used when FIREBASE_CREDENTIALS_B64 is not set.
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json

# Optional: base64 of the full firebase_credentials.json content.
# If set, the bot will use this and ignore FIREBASE_CREDENTIALS_PATH.
FIREBASE_CREDENTIALS_B64=
